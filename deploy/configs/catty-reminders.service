[Unit]
Description=Catty Reminders App
After=network.target

[Service]
User=lina
WorkingDirectory=/home/lina/catty-reminders-app
EnvironmentFile=/home/lina/catty-reminders-app/deployref
ExecStart=/home/lina/catty-reminders-app/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
